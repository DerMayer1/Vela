# Database
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/vela_health"

# Auth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Rate limiting (optional in local dev; required in production for distributed limits)
# Without these, rate limiting falls back to a per-instance in-memory store.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
